---
/*
  Pagination Pattern

  Props:
    currentPage: number                   # Current page number (required)
    totalPages: number                    # Total number of pages (required)
    baseUrl: string                       # Base URL for page links e.g. '/blog' (required)

  Examples:
    <Pagination currentPage={2} totalPages={10} baseUrl="/blog" />
*/

import './pagination.css';
import Link from '@components/link/Link.astro';

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

const getPageUrl = (page: number) =>
  page === 1 ? baseUrl : `${baseUrl}/page/${page}`;

const pages: (number | '...')[] = [];

if (totalPages <= 7) {
  for (let i = 1; i <= totalPages; i++) pages.push(i);
} else {
  pages.push(1);
  if (currentPage > 3) pages.push('...');
  for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
    pages.push(i);
  }
  if (currentPage < totalPages - 2) pages.push('...');
  pages.push(totalPages);
}
---

<nav class="p-pagination" aria-label="Pagination">
  <div class="p-pagination__prev">
    <Link
      text="Prev"
      url={currentPage > 1 ? getPageUrl(currentPage - 1) : '#'}
      icon="arrow-left"
      iconOrientation="left"
      classes={`p-pagination__link${currentPage === 1 ? ' is-disabled' : ''}`}
    />
  </div>

  <div class="p-pagination__pages">
    {pages.map(page => (
      page === '...' ? (
        <span class="p-pagination__ellipsis">…</span>
      ) : (
        <a
          href={getPageUrl(page)}
          class:list={['p-pagination__page', { 'is-current': page === currentPage }]}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      )
    ))}
  </div>

  <div class="p-pagination__next">
    <Link
      text="Next"
      url={currentPage < totalPages ? getPageUrl(currentPage + 1) : '#'}
      icon="arrow-right"
      classes={`p-pagination__link${currentPage === totalPages ? ' is-disabled' : ''}`}
    />
  </div>
</nav>