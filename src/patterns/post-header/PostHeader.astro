---
/*
  PostHeader Pattern

  A two-column header for blog posts with image on the left
  and breadcrumb, title, excerpt, meta and share links on the right.

  Props:
    title: string                         # Post title (required)
    image?: ImageMetadata | string        # Post image
    imageAlt?: string                     # Image alt text (default: '')
    excerpt?: string                      # Post excerpt
    category?: string                     # Post category
    categoryHref?: string                 # Link to category page
    date?: string                         # Publication date
    readTime?: string                     # Read time
    shareUrl?: string                     # URL to share (default: current URL)

  Examples:
    <PostHeader
      title="Canyon at sunset"
      image="https://images.unsplash.com/..."
      imageAlt="Canyon landscape"
      excerpt="A drive through the canyon country of southern Utah."
      category="Photography"
      categoryHref="/blog/photography"
      date="July 4, 2026"
      readTime="5 min read"
    />
*/

import './post-header.css';
import Breadcrumb from '@components/breadcrumb/Breadcrumb.astro';
import Heading from '@components/heading/Heading.astro';
import RichText from '@components/rich-text/RichText.astro';
import IconGroup from '@patterns/icon-group/IconGroup.astro';
import PostMeta from '@components/post-meta/PostMeta.astro';
import Image from '@components/image/Image.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  image?: ImageMetadata | string;
  imageAlt?: string;
  excerpt?: string;
  category?: string;
  categoryHref?: string;
  date?: string;
  readTime?: string;
  shareUrl?: string;
}

const {
  title,
  image,
  imageAlt = '',
  excerpt,
  category,
  categoryHref,
  date,
  readTime,
  shareUrl = Astro.url.href,
} = Astro.props;

const breadcrumbItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  ...(category ? [{ href: categoryHref, label: category }] : []),
];

const shareLinks = [
  { name: 'twitter', url: `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(title)}`, label: 'Share on Twitter' },
  { name: 'facebook', url: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`, label: 'Share on Facebook' },
];
---

<header class="p-post-header">
  <div class="p-post-header__image">
    {image && (
      <Image src={image} alt={imageAlt} classes="w-full h-full object-cover" />
    )}
  </div>
  <div class="p-post-header__content-wrapper container mx-auto">
    <div class="p-post-header__content">
      <div class="space-y-6 md:space-y-8">
        <div class="space-y-3">
          <Breadcrumb items={breadcrumbItems} />
          <Heading text={title} tag="h2" />
        </div>
        {excerpt && (
          <RichText variant="large" content={`<p>${excerpt}</p>`} />
        )}
        <div class="space-y-3">
          <PostMeta date={date} readTime={readTime} classes="text-base text-gray-600" />
          <div class="p-post-header__share">
            <span class="text-gray-600">Share:</span>
            <IconGroup
              classes="flex gap-3"
              icons={shareLinks.map(link => ({
                name: link.name,
                tag: 'a',
                url: link.url,
                target: '_blank',
                label: link.label,
                classes: 'bg-gray-200 text-gray-900 h-8 w-8',
                attrs: { rel: 'noopener noreferrer' }
              }))}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</header>