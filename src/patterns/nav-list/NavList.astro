---
/*
  Nav List Pattern

  A reusable list of navigation links.
  Used in both header and footer navigation.

  Props:
    links: { href: string, label: string, classes?: string }[]  # Nav links (required)
    classes?: string                                            # Additional classes for ul
    linkClasses?: string                                        # Additional classes for all links
    showActive?: boolean                                        # Show active state (default: true)

  Examples:
    <NavList links={navLinks} />

    <NavList
      links={navLinks}
      classes="p-nav-list--mobile"
      linkClasses="text-xl text-gray-100"
      showActive={false}
    />
*/

import './nav-list.css';

interface NavLink {
  href: string;
  label: string;
  classes?: string;
}

interface Props {
  links: NavLink[];
  classes?: string;
  linkClasses?: string;
  showActive?: boolean;
}

const {
  links = [],
  classes = '',
  linkClasses = '',
  showActive = true,
} = Astro.props;

const ulClass = ['p-nav-list', classes].filter(Boolean).join(' ');
const baseLinkClass = ['p-nav-list__link', linkClasses].filter(Boolean).join(' ');

const isActive = (href: string) => Astro.url.pathname === href;
---

<ul class={ulClass}>
  {links.map((link) => {
    const linkClass = [baseLinkClass, link.classes].filter(Boolean).join(' ');
    return (
      <li class="p-nav-list__item">
        <a
          href={link.href}
          class={linkClass}
          aria-current={showActive && isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      </li>
    );
  })}
</ul>

<script>
  function setActiveLink() {
    document.querySelectorAll('.p-nav-list__link').forEach(link => {
      const href = link.getAttribute('href');
      if (href === window.location.pathname) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  }

  document.addEventListener('astro:page-load', setActiveLink);
</script>