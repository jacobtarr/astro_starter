---
/*
  Layout: Page

  Middle layer between Base and page templates.
  Handles page wrapper and optional container.

  Props:
    useContainer?: boolean            # Wrap content in container (default: false)
    containerClasses?: string         # Additional classes for .l-page-container

  Examples:
    <Page>
      content
    </Page>

    <Page useContainer containerClasses="py-16">
      content
    </Page>
*/

import Base from './Base.astro';
import Header from '@globals/header/Header.astro';
import Footer from '@globals/footer/Footer.astro';

interface Props {
  useContainer?: boolean;
  containerClasses?: string;
}

const slug = Astro.url.pathname.replace(/^\/|\/$/g, '') || 'home';
const bodyClass = `l-body-${slug}`;
const pageClass = `l-page-container l-page-${slug}`;

const {
  useContainer = false,
  containerClasses = '',
} = Astro.props;

const containerClassName = ['l-page-container__inner container mx-auto', containerClasses].filter(Boolean).join(' ');
---

<Base bodyClass={bodyClass}>
  <Header />
  <main class="l-site-container">
    <div class={pageClass}>
      {useContainer ? (
        <div class={containerClassName}>
          <slot />
        </div>
      ) : (
        <slot />
      )}
    </div>
  </main>
  <Footer />
</Base>