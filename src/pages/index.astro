---
import Page from '@layouts/Page.astro';
import SplitMedia from '@blocks/splitMedia/SplitMedia.astro';
import Button from '@components/button/Button.astro';
import Heading from '@components/heading/Heading.astro';

const splitMediaData = {
  heading: "Split Media Block",
  content: `
    <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Aspernatur ut voluptas aliquid.</p>
    <p>Another paragraph here with <strong>bold text</strong> and <em>italic text</em>.</p>
    <ul>
      <li>List item one</li>
      <li>List item two</li>
      <li>List item three</li>
    </ul>
  `,
  image: "https://images.unsplash.com/photo-1782605626069-a4007aee78a1?q=80&w=2340&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  imageAlt: "Canyon landscape",
};

const splitMediaDataReversed = {
  heading: "Split Media Block Reversed",
  content: `
    <p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Aspernatur ut voluptas aliquid.</p>
    <p>Another paragraph here with <strong>bold text</strong> and <em>italic text</em>.</p>
  `,
  image: "https://images.unsplash.com/photo-1782605626069-a4007aee78a1?q=80&w=2340&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
  imageAlt: "Canyon landscape",
};

---

<Page
  bodyClass="l-page-home"
  pageClasses=""
>
  <SplitMedia {...splitMediaData} />
  <SplitMedia {...splitMediaDataReversed} reverse />
  <SplitMedia {...splitMediaData} />
  <h3>Headings</h3>
  <Heading text="Heading 1" tag='h1' />
  <Heading text="Heading 2" tag='h2' />
  <Heading text="Heading 3" tag='h3' />
  <Heading text="Heading 4" tag='h4' />
  <Heading text="Heading 5" tag='h5' />
  <Heading text="Heading 6" tag='h6' />
      
  <div class="space-y-4">
    <h3>Buttons</h3>
    <div class="flex gap-4">
      <Button text='Primary' icon='arrow-right'></Button>
      <Button text='Secondary' variant='secondary' icon='arrow-right'></Button>
    </div>
    
  </div>
      
</Page>