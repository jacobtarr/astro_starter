---
import Page from '@layouts/Page.astro';
import RichText from '@components/rich-text/RichText.astro';
import TableOfContents from '@components/table-of-contents/TableOfContents.astro';
import IconGroup from '@patterns/icon-group/IconGroup.astro';
import PostHeader from '@patterns/post-header/PostHeader.astro';
import CardGroup from '@patterns/card-group/CardGroup.astro';
import { capitalize } from '@src/utils/helpers';
import FigureMdx from '@components/figure/FigureMdx.astro'; 
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const shareUrl = Astro.url.href;

const { Content, headings } = await render(post);

const allPosts = await getCollection('blog');

const relatedPosts = allPosts
  .filter(entry => entry.id !== post.id)
  .filter(entry => entry.data.category === post.data.category)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 3);

const shareLinks = [
  { name: 'twitter', url: `https://twitter.com/intent/tweet?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(post.data.title)}`, label: 'Share on Twitter' },
  { name: 'facebook', url: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`, label: 'Share on Facebook' },
];
---

<Page>
  <PostHeader
    title={post.data.title}
    image={post.data.thumbnail}
    imageAlt={post.data.thumbnailAlt}
    excerpt={post.data.excerpt}
    category={post.data.category}
    categoryHref={post.data.category ? `/blog/category/${post.data.category.toLowerCase()}` : undefined}
    date={post.data.date}
    readTime={post.data.readTime}
  />
  <div class="container mx-auto py-12 md:py-20">
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-16">
      <div class="hidden lg:block col-span-3">
        <TableOfContents headings={headings} />
      </div>
      <article id="post-content" class="col-span-2 lg:col-span-6 max-w-3xl mx-auto space-y-12 md:space-y-20">
        <RichText variant="large">
          <Content components={{ img: FigureMdx }} />
        </RichText>
        <div class="flex items-center gap-3 pt-6 border-t border-gray-200">
          <span class="text-gray-600">Share:</span>
          <IconGroup
            classes="flex gap-3"
            icons={shareLinks.map(link => ({
              name: link.name,
              tag: 'a',
              url: link.url,
              target: '_blank',
              label: link.label,
              classes: 'bg-gray-200 text-gray-900 h-8 w-8',
              attrs: { rel: 'noopener noreferrer' }
            }))}
          />
        </div>
      </article>
    </div>
  </div>
  {relatedPosts.length > 0 &&
    <CardGroup
      posts={relatedPosts}
      heading={`More from ${capitalize(post.data.category ?? '')}`}
    />
  }
  
</Page>