---
/*
  Figure Component

  Semantic image wrapper with optional caption.
  Composes the Image component with a figcaption.

  Props:
    src: ImageMetadata | string           # Image (required)
    alt: string                           # Alt text (required)
    caption?: string                      # Optional caption text
    loading?: 'lazy' | 'eager'            # Loading strategy (default: 'lazy')
    widths?: number[]                     # Srcset widths, passed to Image
    sizes?: string                        # CSS sizes attribute, passed to Image
    classes?: string                      # Additional classes for figure

  Examples:
    <Figure
      src={photo}
      alt="Canyon landscape"
    />

    <Figure
      src={photo}
      alt="Canyon landscape"
      caption="Grand Staircase-Escalante, Utah"
      loading="eager"
      sizes="(max-width: 767px) 100vw, 50vw"
      classes="my-8"
    />
*/

import './figure.css';
import Image from '@components/image/Image.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  loading?: 'lazy' | 'eager';
  widths?: number[];
  sizes?: string;
  classes?: string;
}

const {
  src,
  alt,
  caption,
  loading = 'lazy',
  widths,
  sizes,
  classes = '',
} = Astro.props;
---

<figure class={`c-figure${classes ? ` ${classes}` : ''}`}>
  <Image src={src} alt={alt} loading={loading} widths={widths} sizes={sizes} />
  {caption && <figcaption class="c-figure__caption">{caption}</figcaption>}
</figure>