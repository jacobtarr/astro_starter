---
/*
  Image Component

  Wraps Astro's built-in Image component with sensible defaults.
  Handles WebP conversion, srcset, and lazy loading automatically.
  Supports art direction via optional mobileSrc prop.

  Props:
    src: ImageMetadata | string           # Main image (required)
    alt: string                           # Alt text (required)
    mobileSrc?: ImageMetadata | string    # Optional mobile image for art direction
    widths?: number[]                     # Srcset widths (default: [400, 800, 1200])
    sizes?: string                        # CSS sizes attribute (default: '(max-width: 767px) 100vw, 50vw')
    loading?: 'lazy' | 'eager'            # Loading strategy (default: 'lazy')
    classes?: string                      # Additional classes

  Examples:
    <Image src={photo} alt="Canyon landscape" />

    <Image
      src={desktopPhoto}
      mobileSrc={mobilePhoto}
      alt="Canyon landscape"
      sizes="100vw"
      loading="eager"
    />
*/

import './image.css';
import { getImage, Image as AstroImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  mobileSrc?: ImageMetadata | string;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  classes?: string;
}

const {
  src,
  alt,
  mobileSrc,
  widths = [400, 800, 1200],
  sizes = '(max-width: 767px) 100vw, 50vw',
  loading = 'lazy',
  classes = '',
} = Astro.props;

const className = `c-image${classes ? ` ${classes}` : ''}`;

// Only use getImage when art direction is needed
const mobileImg = mobileSrc && typeof mobileSrc !== 'string'
  ? await getImage({ src: mobileSrc, format: 'webp', width: 800 })
  : null;

const desktopImg = mobileSrc && typeof src !== 'string'
  ? await getImage({ src, format: 'webp', width: 1600 })
  : null;
---

{mobileSrc && mobileImg && desktopImg ? (
  <picture>
    <source media="(max-width: 767px)" srcset={mobileImg.src} />
    <source media="(min-width: 768px)" srcset={desktopImg.src} />
    <img src={desktopImg.src} alt={alt} loading={loading} class={className} />
  </picture>
) : typeof src === 'string' ? (
  <img src={src} alt={alt} loading={loading} class={className} />
) : (
  <AstroImage
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={loading}
    format="webp"
    class={className}
  />
)}