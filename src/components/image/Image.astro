---
/*
  Image Component

  Wraps Astro's built-in Image component with sensible defaults.
  Handles WebP conversion, srcset, and lazy loading automatically.

  Props:
    src: ImageMetadata                    # Imported image (required)
    alt: string                           # Alt text (required)
    widths?: number[]                     # Srcset widths (default: [400, 800, 1200])
    sizes?: string                        # CSS sizes attribute (default: '(max-width: 767px) 100vw, 50vw')
    loading?: 'lazy' | 'eager'            # Loading strategy (default: 'lazy')
    classes?: string                      # Additional classes

  Examples:
    import photo from '@assets/images/photo.jpg';

    <Image src={photo} alt="Canyon landscape" />

    <Image
      src={photo}
      alt="Hero image"
      widths={[600, 1200, 1800]}
      sizes="100vw"
      loading="eager"
    />
*/

import './image.css';

import { Image as AstroImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  classes?: string;
}

const {
  src,
  alt,
  widths = [400, 800, 1200],
  sizes = '(max-width: 767px) 100vw, 50vw',
  loading = 'lazy',
  classes = '',
} = Astro.props;
---

{typeof src === 'string' ? (
  <img
    src={src}
    alt={alt}
    loading={loading}
    class={`c-image${classes ? ` ${classes}` : ''}`}
  />
) : (
  <AstroImage
    src={src}
    alt={alt}
    widths={widths}
    sizes={sizes}
    loading={loading}
    format="webp"
    class={`c-image${classes ? ` ${classes}` : ''}`}
  />
)}