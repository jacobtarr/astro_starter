---
/*
  FormField Component

  A labeled form input or textarea.

  Props:
    type?: 'text' | 'email' | 'tel' | 'textarea'    # Field type (default: 'text')
    id: string                                      # Field id, used for label association (required)
    name: string                                    # Field name (required)
    label: string                                   # Label text (required)
    autocomplete?: string                           # Autocomplete attribute
    rows?: number                                   # Rows for textarea (default: 4)
    required?: boolean                              # Required field (default: false)
    hideLabel?: boolean                             # Option to hide label (default: false)
    classes?: string                                # Additional classes for wrapper

  Examples:
    <FormField id="first-name" name="first-name" label="First name" autocomplete="given-name" />
    <FormField type="email" id="email" name="email" label="Email" autocomplete="email" required />
    <FormField type="textarea" id="message" name="message" label="Message" rows={4} />
*/

import './form-field.css';

interface Props {
  type?: 'text' | 'email' | 'tel' | 'textarea';
  id: string;
  name: string;
  label: string;
  autocomplete?: string;
  rows?: number;
  required?: boolean;
  hideLabel?: boolean;
  classes?: string;
}

const {
  type = 'text',
  id,
  name,
  label,
  autocomplete,
  rows = 4,
  required = false,
	hideLabel = false,
  classes = '',
} = Astro.props;

const fieldClass = 'c-form-field';
---

<div class={`space-y-2 ${classes}`}>
  <label for={id} class={hideLabel ? 'sr-only' : 'block'}>{label}</label>
  {type === 'textarea' ? (
    <textarea
      id={id}
      name={name}
      rows={rows}
      required={required}
      class={fieldClass}
    />
  ) : (
    <input
      id={id}
      type={type}
      name={name}
      autocomplete={autocomplete}
      required={required}
      class={fieldClass}
    />
  )}
</div>