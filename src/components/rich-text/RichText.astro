---
/*
  RichText Component

  Props:
    content?: string                              # HTML content (omit to use the default slot instead)
    variant?: 'default'|'small'|'medium'|'large'  # Size variant (default: 'default')
    theme?: 'light' | 'dark'                      # Theme (default: 'light')
    classes?: string                              # Additional classes
    attrs?: Record<string, string>                # Additional attributes

  Examples:
    <RichText content="<p>Lorem ipsum...</p>" />

    <RichText variant="large" theme="dark" classes="my-8">
      <Content />
    </RichText>
*/

import './rich-text.css';

interface Props {
  content?: string;
  variant?: 'default' | 'small' | 'medium' | 'large';
  theme?: 'light' | 'dark';
  classes?: string;
  attrs?: Record<string, string>;
}

const {
  content,
  variant = 'default',
  theme = 'light',
  classes = '',
  attrs = {},
} = Astro.props;

const variantClasses: Record<string, string> = {
  small: 'c-rich-text--small',
  medium: 'c-rich-text--medium',
  large: 'c-rich-text--large',
  default: '',
};

const className = [
  'c-rich-text',
  variantClasses[variant] ?? '',
  theme === 'dark' ? 'c-rich-text--dark' : '',
  classes,
].filter(Boolean).join(' ');
---

{content ? (
  <div class={className} {...attrs} set:html={content} />
) : Astro.slots.has('default') ? (
  <div class={className} {...attrs}><slot /></div>
) : null}