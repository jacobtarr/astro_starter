---
/*
  Link Component

  A text link with optional icon. No background or padding — 
  use Button for CTA-style links.

  Props:
    text?: string                          # Link text
    url?: string                           # Link URL (default: '#')
    target?: string                        # Link target (default: '_self')
    icon?: string                          # Icon name (optional)
    iconClasses?: string                   # Additional classes for icon
    iconOrientation?: 'left' | 'right'     # Icon position (default: 'right')
    iconReverse?: boolean                  # Flip icon (default: false)
    theme?: 'light' | 'dark'               # Theme (default: 'light')
    classes?: string                       # Additional classes
    attrs?: Record<string, string>         # Additional HTML attributes

  Examples:
    <Link text="Learn more" url="/about" />

    <Link
      text="Read the full post"
      url="/blog/canyon"
      icon="arrow"
      iconOrientation="right"
    />
*/

import './link.css';
import Icon from '@components/icon/Icon.astro';

interface Props {
  text?: string;
  url?: string;
  target?: string;
  icon?: string;
	iconClasses?: string;
  iconOrientation?: 'left' | 'right';
  iconReverse?: boolean;
  theme?: 'light' | 'dark';
  classes?: string;
  attrs?: Record<string, string>;
}

const {
  text,
  url = '#',
  target = '_self',
  icon,
  iconOrientation = 'right',
  iconReverse = false,
  theme = 'light',
  classes = '',
	iconClasses = '',
  attrs = {},
} = Astro.props;

const hasIcon = !!icon;

const className = [
  'c-link',
  `c-link--${theme}`,
  hasIcon ? 'has-icon' : '',
  classes,
].filter(Boolean).join(' ');
---

<a href={url} target={target} class={className} {...attrs}>
  {hasIcon && iconOrientation === 'left' && (
		<div class={`c-link__icon c-link__icon--left${iconReverse ? ' c-link__icon--reverse' : ''}`}>
			<Icon name={icon} classes={iconClasses} />
		</div>
	)}
  {text && <span class="c-link__text">{text}</span>}
  {hasIcon && iconOrientation === 'right' && (
    <div class={`c-link__icon c-link__icon--right${iconReverse ? ' c-link__icon--reverse' : ''}`}>
      <Icon name={icon} classes={iconClasses} />
    </div>
  )}
</a>