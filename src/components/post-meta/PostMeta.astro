---
/*
  PostMeta Component

  Displays post date and read time. Formats ISO dates automatically.

  Props:
    date?: string                         # Date string e.g. "2026-07-04" or "July 4, 2026"
    readTime?: string                     # Read time e.g. "5 min read"
    classes?: string                      # Additional classes

  Examples:
    <PostMeta date="2026-07-04" readTime="5 min read" />
    <PostMeta date="2026-07-04" />
*/

import './post-meta.css';

interface Props {
  date?: string;
  readTime?: string;
  classes?: string;
}

const { date, readTime, classes = '' } = Astro.props;

const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    })
  : undefined;

const className = ['c-post-meta', classes].filter(Boolean).join(' ');
---

{(date || readTime) && (
  <div class={className}>
    {formattedDate && <span>{formattedDate}</span>}
    {formattedDate && readTime && <span> · </span>}
    {readTime && <span>{readTime}</span>}
  </div>
)}