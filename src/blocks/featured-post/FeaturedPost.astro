---
/*
  FeaturedPost Block

  A two-column layout with an image on the left and content on the right.
  Used to highlight a featured blog post.

  Props:
    eyebrow?: string                      # Eyebrow text above heading
    heading?: string                      # Post title
    content?: string                      # HTML content for excerpt
    image?: ImageMetadata | string        # Post image
    imageAlt?: string                     # Image alt text (default: '')
    imageCaption?: string                 # Optional image caption
    href?: string                         # Link to post
    date?: string                         # Publication date
    readTime?: string                     # Read time
    useBlockContainer?: boolean           # Wrap in container (default: true)
    useBlockSpacing?: boolean             # Add vertical spacing (default: true)
    blockClasses?: string                 # Additional block classes

  Examples:
    <FeaturedPost
      eyebrow="Featured Post"
      heading="Canyon at Sunset"
      image="https://images.unsplash.com/..."
      imageAlt="Canyon landscape"
      href="/blog/canyon"
      date="July 4, 2026"
      readTime="5 min read"
    />
*/

import Block from '@blocks/_base/Block.astro';
import Figure from '@components/figure/Figure.astro';
import Eyebrow from '@components/eyebrow/Eyebrow.astro';
import Heading from '@components/heading/Heading.astro';
import RichText from '@components/rich-text/RichText.astro';
import PostMeta from '@components/post-meta/PostMeta.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  heading?: string;
  content?: string;
  image?: ImageMetadata | string;
  imageAlt?: string;
  imageCaption?: string;
  href?: string;
  date?: string;
  readTime?: string;
  useBlockContainer?: boolean;
  useBlockSpacing?: boolean;
  blockClasses?: string;
}

const {
  eyebrow,
  heading,
  content,
  image,
  imageAlt = '',
  imageCaption,
  href,
  date,
  readTime,
  useBlockContainer = true,
  useBlockSpacing = true,
  blockClasses = '',
} = Astro.props;

const contentClass = image ? 'col-span-2 md:col-span-6' : 'col-span-2 md:col-span-12';
const imageClass = 'col-span-2 md:col-span-6';
---

<Block
  handle="featured-post"
  useBlockContainer={useBlockContainer}
  useBlockSpacing={useBlockSpacing}
  blockClasses={blockClasses}
>
  <div class="grid grid-cols-2 md:grid-cols-12 items-center gap-8 lg:gap-20">
    <div class={imageClass}>
      {image && (
        href ? (
          <a href={href} class="b-featured-post__image">
            <Figure
              src={image}
              alt={imageAlt}
              caption={imageCaption}
              loading="eager"
              widths={[400, 800, 1200]}
              sizes="(max-width: 767px) 100vw, 50vw"
            />
          </a>
        ) : (
          <Figure
            src={image}
            alt={imageAlt}
            caption={imageCaption}
            loading="eager"
            widths={[400, 800, 1200]}
            sizes="(max-width: 767px) 100vw, 50vw"
          />
        )
      )}
    </div>
    <div class={contentClass}>
      <div class="space-y-6">
        <div class="space-y-3">
          {eyebrow && <Eyebrow text={eyebrow} />}
          {heading && (
            <Heading
              text={heading}
              size="h1"
              tag={href ? 'a' : 'h1'}
              attrs={href ? { href } : {}}
            />
          )}
        </div>
        {content ? (
          <RichText content={content} variant="large" />
        ) : Astro.slots.has('default') ? (
          <RichText variant="large"><slot /></RichText>
        ) : null}
        <PostMeta date={date} readTime={readTime} classes="text-gray-500 text-base" />
      </div>
    </div>
  </div>
</Block>