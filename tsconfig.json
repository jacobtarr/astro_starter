{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@styles/*": ["src/styles/*"],
      "@blocks/*": ["src/blocks/*"],
      "@components/*": ["src/components/*"],
      "@patterns/*": ["src/patterns/*"],
      "@globals/*": ["src/globals/*"],
      "@layouts/*": ["src/layouts/*"],
      "@assets/*": ["src/assets/*"],
      "@src/*": ["./src/*"],
    }
  }
}
